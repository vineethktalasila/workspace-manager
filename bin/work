#!/bin/zsh
# ==============================================================================
# Workspace Manager Core CLI Router
# ==============================================================================

# 1. Enforce Configuration Loading
if [[ -f "$HOME/.workspace.conf" ]]; then
    source "$HOME/.workspace.conf"
else
    echo "Fatal: Configuration file ~/.workspace.conf not found." >&2
    exit 1
fi

SUBCOMMAND=$1
shift # Shift arguments so $1 becomes the first option after the subcommand

# 2. Route Subcommands
case "$SUBCOMMAND" in
    new)
        exec "$WS_PROJECTS/workspace-manager/bin/create_project.sh" "$@"
        ;;
    delete)
        exec "$WS_PROJECTS/workspace-manager/bin/delete_project.sh" "$@"
        ;;
    list)
        echo "=== Available Projects ==="
        if [[ -d "$WS_PROJECTS" ]]; then
            # Use Zsh array expansion to cleanly list directories
            local projects=("$WS_PROJECTS"/*(/N:t))
            if (( ${#projects[@]} == 0 )); then
                echo " (No projects found)"
            else
                printf '  - %s\n' "${projects[@]}"
            fi
        fi
        echo "=========================="
        ;;
    start|stop|change|backup)
        echo "Subcommand '$SUBCOMMAND' is recognized and will be fully integrated soon."
        ;;

esac
