#!/bin/zsh
# ==============================================================================
# Workspace Manager Core CLI Router
# ==============================================================================

# 1. Enforce Configuration Loading
if [[ -f "$HOME/.workspace.conf" ]]; then
    source "$HOME/.workspace.conf"
else
    echo "Fatal: Configuration file ~/.workspace.conf not found." >&2
    exit 1
fi

SUBCOMMAND=$1
shift # Shift arguments so $1 becomes the first option after the subcommand

# 2. Route Subcommands
case "$SUBCOMMAND" in
    new)
        # Execute the scaffolding engine and pass along all remaining arguments
        exec "$WS_PROJECTS/workspace-manager/bin/create_project.sh" "$@"
        ;;
    start|stop|change|delete|list|backup)
        echo "Subcommand '$SUBCOMMAND' is recognized and will be implemented in Step 3."
        ;;
    -h|--help|*)
        echo "Usage: work <command> [options]"
        echo ""
        echo "Commands:"
        echo "  new      Scaffold a new project environment"
        echo "  start    Activate a project workspace"
        echo "  stop     Teardown and sync the active workspace"
        echo "  change   Switch to a different project workspace"
        echo "  delete   Purge a workspace locally and remotely"
        echo "  list     List all available workspace projects"
        echo "  backup   Sync workspace environments and codebases to external storage"
        ;;
esac
